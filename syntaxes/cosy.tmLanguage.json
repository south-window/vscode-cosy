{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "COSY",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#constants"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#comments"
		},
		{
			"include": "#math"
		},
		{
			"include": "#typefunctions"
		},
		{
			"include": "#stringfunctions"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#endfunctions"
		},
		{
			"include": "#BeamPhysics"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#ios"
		},
		{
			"include": "#beginends"
		},
		{
			"include": "#procedures"
		},
		{
			"include": "#identifier"
		}

	],

	"repository": {
		"comments": {
			"name": "comment.block.cosy",
			"begin": "\\{",
			"beginCaptures": {
				"0": {
					"name": "punctuation.definition.comment.begin.cosy"
				}
			},
			"end": "\\}",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.comment.end.cosy"
				}
			},
			"patterns": [
				{
					"include": "#comments"
				}
			]
		},

		"identifier": {
			"patterns": [
			  {
				"match": "(?i)([_a-z][0-9_a-z]*)\\s*\\(",
				"captures": {
				  "1": {
					"name": "entity.name.function.cosy"
				  }
				}
			  },
			  {
				"name": "variable.other.cosy",
				"match": "(?i)\\b([_a-z][0-9_a-z]*)\\b(?!\\s*\\.)"
			  },
			  {
				"name": "entity.name.class.cosy",
				"match": "(?i)\\b([_a-z][0-9_a-z]*)\\b"
			  }
			]
		  },

		"keywords": {
			"patterns": [{
				"name": "keyword.control.cosy",
				"match": "(?xi)\\b(if|endif|elseif|else|while|endwhile|loop|endloop|ploop|endploop|fit|endfit|begin|end|quit|clear)\\b"
			}]
		},
		"strings": {
			"name": "string.quoted.single.cosy",
			"begin": "'",
			"beginCaptures": {
				"0": {
					"name": "punctuation.definition.string.begin.cosy"
				}
			},
			"end": "'(?!')",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.string.end.cosy"
				}
			},
			"patterns": [
				{
					"name": "constant.character.escape.cosy",
					"match": "''"
				}
			]
		},

		"math": {
			"patterns": [
			  {
				"match": "(?xi)\\b(?<!\\.)(sqrt|log|exp|sin|cos|tan|asin|acos|atan|sinh|cosh|tanh|isrt|isrt3|sqr|abs|mod|real|imag|cons|length)\\b",
				"name": "entity.name.function.cosy"
			  }

			]
		},
		"numbers":{
			"patterns": [
				{
					"name": "constant.numeric.float.cosy",
					"match": "(?xi)(?<![._a-z0-9])(?:(?:[0-9]+\\.[0-9]*|\\.[0-9]+)(?:[ed][+-]?[0-9]+)?|[0-9]+[ed][+-]?[0-9]+)(?![._a-z0-9])"
				},
				{
					"name": "constant.numeric.integer.cosy",
					"match": "(?xi)(?<![._a-z0-9])[0-9]+(?![._a-z0-9])"
				}
			]
		},
		"BeamPhysics":{
			"patterns": [
				{
					"name": "entity.name.function.cosy",
					"match": "(?xi)\\b(rp|rpe|rpp|rpr|rpm|rps|sb|sp|sbe|um|sm|snm|am|anm|pm|psm|wm|rm|wsm|rsm|me|sigma|mr|mt|sr|ssr|er|scde|envel|encl|cr|pray|wray|pr|rray|sray|lray|aray|addrays|pspi|wspi|rspi|sspi|lspi|aspi|addspis|pty|bp|ep|pp|pg|pge|ps|dl|cb|mq|mh|mo|md|mz|m5|mm|mms|eq|eh|eo|ed|ez|e5|em|ems|ms|es|ec|ecl|esp|di|mss|dp|mc|wf|wc|wi|rf|cmr|cml|cmsi|cms|cmst|cmg|cel|cea|ceg|fr|fc|fp|fd|eset|wset|crsysca|fc2|fd2|ge|mf|mge|was|wa|bbc|el|wl|gls|gl|gp|gms|gmp|gmf|gm|sa|ta|ra|pa|ma|pt|ar|rr|tp|nf|ts|tsc|rfilt|rs|mcm|ecm|tsp|tss|tr|trt|trr|trap|ap|trapn|traphist|traypac|trpray|trpspi|se|wset|oe|sy|mgf|gfm|mlf|lfm|lflf|der|integ|pb|nmon|polval|ov|dil|msk|mqk|m5k)\\b"
				}
			]
		},

		"procedures": {
			"name": "meta.program.cosy",
			"begin": "(?i)\\b(procedure|function|variable)\\b",
			"beginCaptures": {
			  "1": {
				"name": "storage.type.cosy"
			  }
			},
			"end": ";",
			"patterns": [
			  {
				"name": "comment.block.cosy",
				"begin": "\\{",
				"end": "\\}",
				"patterns": [
				  {
					"include": "#comments"
				  }
				]
			  },
			  {
				"name": "entity.name.function.cosy",
				"match": "(?i)([_a-z][0-9_a-z]*)"
			  }
			]
		  },

		"endfunctions":{
			"patterns": [
				{
					"name": "storage.type.cosy",
					"match": "(?xi)\\b(endprocedure|endfunction)\\b"
				}
			]
		},

		"operators": {
			"patterns": [
			  {
				"match": "<=|>=|=|#|<|>",
				"name": "keyword.operator.comparison.cosy"
			  },
			  {
				"match": ":=",
				"name": "keyword.operator.assignment.cosy"
			  },
			  {
				"match": "\\+|-|\\*|/|%",
				"name": "keyword.operator.arithmetic.cosy"
			  },
			  {
				"match": "&|\\|",
				"name": "keyword.operator.special.cosy"
			  }
			]
		},

		"ios":{
			"patterns": [
				{
					"name": "entity.name.tag.cosy",
					"match": "(?xi)\\b(read|write|include|save)\\b"
				}
			]
		},

		  "beginends":{
			  "patterns": [
			  ]
		  },

		  "constants": {
			"patterns": [
				{
					"name": "constant.language.cosy",
					"match": "(?xi)\\b(true|false)\\b"
				},
				{
					"name": "constant.numeric.cosy",
					"match": "(?xi)\\b(pi|degrad|amu|amumev|ezero|clight)\\b"
				}
			]
		  },

		  "typefunctions": {
			"patterns": [
				{
					"name": "entity.name.type.cosy",
					"match": "(?xi)\\b(lo|cm|da|cd|ve|st|re)\\b(?=\\s*\\()"
				}
			]
		  },

		  "stringfunctions": {
			"patterns": [
				{
					"name": "entity.name.function.cosy",
					"match": "(?xi)\\b(s|sf|vmax|lst|lcd|lcm)\\b(?=\\s*\\()"
				}
			]
		  }


	},
	"scopeName": "source.fox"
}