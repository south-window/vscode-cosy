{
  "name": "cosy",
  "publisher": "AoLiu",
  "displayName": "COSY Infinity",
  "description": "Syntax highlighting for beam dynamics simulation and analysis code COSY INFINITY.",
  "version": "0.0.4",
  "icon": "images/cosy.png",
  "engines": {
    "vscode": "^1.79.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/south-window/vscode-cosy"
  },
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "test": "vscode-tmgrammar-test -g syntaxes/cosy.tmLanguage.json 'tests/syntax/**/*.test.fox'",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1",
    "vscode-tmgrammar-test": "^0.1.3"
  },
  "files": [
    "CHANGELOG.md",
    "images/cosy.png",
    "language-configuration.json",
    "LICENSE",
    "README.md",
    "syntaxes/cosy.tmLanguage.json"
  ],
  "contributes": {
    "languages": [{
      "id": "cosy",
      "aliases": ["COSY", "cosy"],
      "extensions": [".fox"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "cosy",
      "scopeName": "source.fox",
      "path": "./syntaxes/cosy.tmLanguage.json"
    }]
  }
}
